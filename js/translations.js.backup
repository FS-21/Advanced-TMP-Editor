const AVAILABLE_LANGUAGES = [
    { code: "en", name: "English", englishName: "English" },
    { code: "ru", name: "Русский", englishName: "Russian" },
    { code: "zh-hant", name: "繁體中文", englishName: "Traditional Chinese" },
    { code: "zh-hans", name: "简体中文", englishName: "Simplified Chinese" },
    { code: "de", name: "Deutsch", englishName: "German" },
    { code: "fr", name: "Français", englishName: "French" },
    { code: "es", name: "Español", englishName: "Spanish" }
];

let currentLanguage = "en";

function loadLanguage() {
    const saved = localStorage.getItem("shp_editor_lang");
    if (saved && TRANSLATIONS[saved]) {
        currentLanguage = saved;
    }
}

function setLanguage(lang) {
    if (TRANSLATIONS[lang]) {
        currentLanguage = lang;
        localStorage.setItem("shp_editor_lang", lang);
        applyTranslations();
    }
}

function t(key) {
    if (TRANSLATIONS[currentLanguage] && TRANSLATIONS[currentLanguage][key]) {
        return TRANSLATIONS[currentLanguage][key];
    }
    // Fallback to English
    if (TRANSLATIONS["en"] && TRANSLATIONS["en"][key]) {
        return TRANSLATIONS["en"][key];
    }
    // If no translation found, just return original text if we stored it, or the key
    return key;
}

// Map of elements to translate. 
// We attach data-i18n attributes in HTML to the target elements.
// This function scans the DOM.
function applyTranslations() {
    const elements = document.querySelectorAll('[data-i18n]');
    elements.forEach(el => {
        const key = el.getAttribute('data-i18n');
        const translated = t(key);
        if (translated === key) return;

        // Smart text replacement: find a direct text node or a simple span containing the text
        let found = false;
        
        // Strategy A: specifically if the element has children like icons, don't just replace textContent of the parent.
        // Instead, find the node that looks like the main text.
        for (const child of el.childNodes) {
            if (child.nodeType === Node.TEXT_NODE && child.textContent.trim().length > 0) {
                child.textContent = translated;
                found = true;
                break;
            }
        }

        // Strategy B: If no text node was found directly, it might be wrapped in a span that doesn't have its own i18n key.
        if (!found) {
            const spans = el.querySelectorAll('span:not(.menu-icon):not(.shortcut):not(.arrow)');
            for (const span of spans) {
                // Only replace if it doesn't have its own data-i18n (to avoid nested translation issues)
                if (!span.hasAttribute('data-i18n')) {
                    span.textContent = translated;
                    found = true;
                    break;
                }
            }
        }

        // Strategy C: If it's a simple element with no children, just replace textContent.
        if (!found && el.children.length === 0) {
            el.textContent = translated;
        }
    });
    
    // Also handle title attributes
    const titles = document.querySelectorAll('[data-i18n-title]');
    titles.forEach(el => {
        const key = el.getAttribute('data-i18n-title');
        const translated = t(key);
        if (translated !== key) {
            el.setAttribute('title', translated);
        }
    });

    updateLanguageSelectorUI();
}

function updateLanguageSelectorUI() {
    const selector = document.getElementById('langSelector');
    if (!selector) return;
    
    selector.innerHTML = '';
    AVAILABLE_LANGUAGES.forEach(lang => {
        const opt = document.createElement('option');
        opt.value = lang.code;
        
        // Name of this language in the current UI language (fallback to native name)
        let localizedName = t(`lang_${lang.code}`);
        if (localizedName === `lang_${lang.code}`) localizedName = lang.name;

        // Show (English name) in parentheses only when it differs from the localized name
        // e.g. UI=Russian → "Английский (English)", "Русский (Russian)"
        // e.g. UI=English → "English", "Russian", "German" (no parens needed)
        if (localizedName === lang.englishName) {
            opt.textContent = localizedName;
        } else {
            opt.textContent = `${localizedName} (${lang.englishName})`;
        }
        
        selector.appendChild(opt);
    });
    selector.value = currentLanguage;
}

function initLanguageSelector() {
    // Call load language first
    loadLanguage();

    const selector = document.getElementById('langSelector');
    if (selector) {
        selector.addEventListener('change', (e) => {
            setLanguage(e.target.value);
        });
    }

    // Apply translations on startup
    applyTranslations();
}

